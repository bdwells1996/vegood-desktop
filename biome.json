{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "css": {
    "parser": {
      "tailwindDirectives": true
    },
    "linter": {
      "enabled": true,
      "rules": {
        "nursery": {
          "noUnknownAtRule": "off"
        }
      }
    }
  },
  "files": {
    "ignore": ["node_modules", ".next", "storybook-static"]
  }
}
